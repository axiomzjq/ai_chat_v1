# RAG Server Configuration
PORT=3001

# LLM API
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o-mini

# 智谱AI（ZhipuAI）
ZHIPU_API_KEY=your_zhipu_api_key_here
# 智谱知识库 ID（对话调用知识库进行 RAG 问答）
# 在智谱开放平台创建知识库后获取，配置后所有对话会自动调用知识库检索
ZHIPU_KNOWLEDGE_ID=your_knowledge_id_here

# 管理员手机号（可选）
# 当新用户注册时，如果手机号与 ADMIN_PHONE 一致，则自动设为 admin
# 留空或不配置时，所有新用户均为普通用户，管理员需通过管理后台手动提升
ADMIN_PHONE=

# Authing (GenAuth) 配置
# 后端通过 JWKS 和 GraphQL API 验证 Authing access token
AUTHING_APP_ID=your_authing_app_id
AUTHING_APP_HOST=https://your-authing-domain.authing.cn
AUTHING_JWKS_URL=https://your-authing-domain.authing.cn/oidc/.well-known/jwks.json

# Embedding
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=your_embedding_api_key_here

# RAG Parameters
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5

# Optional: Vector Database
# VECTOR_DB_TYPE=memory  # options: memory, chroma, pinecone
