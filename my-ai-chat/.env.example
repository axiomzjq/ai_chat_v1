# 前端环境变量（Vite 项目，必须以 VITE_ 开头）

# API 基础地址
VITE_API_BASE_URL=http://localhost:3001

# Authing (GenAuth) 配置
# 在 Authing/GenAuth 控制台获取应用配置
VITE_AUTHING_APP_ID=your_authing_app_id
VITE_AUTHING_DOMAIN=your-authing-domain.authing.cn
VITE_AUTHING_APP_SECRET=your_authing_app_secret
# VITE_AUTHING_USER_POOL_ID 在弹窗登录组件中需要，选填
VITE_AUTHING_USER_POOL_ID=your_user_pool_id

# 智谱知识库 ID（可选）
# 在智谱开放平台创建知识库后获取，配置后对话会自动调用知识库检索
# 如果前端不配置，后端会使用 server/.env 中的 ZHIPU_KNOWLEDGE_ID 作为默认值
VITE_ZHIPU_KNOWLEDGE_ID=your_knowledge_id_here
