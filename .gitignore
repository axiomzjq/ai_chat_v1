# ============================================
# Git Ignore — D:\zjq 根目录
# 原则：仅排除编译产物和可重新加载的依赖库
# 保留：所有代码、所有知识库、所有参考源码
# ============================================

# --- 依赖库（可通过 npm install 重新加载） ---
node_modules/

# --- 编译产物与构建输出 ---
dist/
dist-ssr/
build/
coverage/
*.tsbuildinfo

# --- 环境变量与密钥（本地配置） ---
.env
.env.local
.env.*.local
server/.env

# --- 日志文件 ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- 编辑器与系统文件 ---
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
Thumbs.db

# --- RAG / AI 生成产物（自动生成，非源码） ---
knowledge-base/processed/*
!knowledge-base/processed/.gitkeep
knowledge-base/embeddings/*
!knowledge-base/embeddings/.gitkeep

# --- 压缩包与二进制分发文件 ---
elitefounder-ai.zip
*.tar.gz
*.rar

# --- Vite 热更新临时文件 ---
*.local

# --- 浏览器抓包文件（可能包含敏感信息） ---
*.har
创始人ip定制文档.zip
